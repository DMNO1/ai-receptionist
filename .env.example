# AI Receptionist 环境配置

# DeepSeek API Key (optional, rule engine works without it)
DEEPSEEK_API_KEY=

# Database (default: SQLite, can use PostgreSQL for production)
DATABASE_URL=sqlite:///ai_receptionist.db

# 企业微信 (WeCom) 配置 - 可选
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_BOSS_USER_ID=
